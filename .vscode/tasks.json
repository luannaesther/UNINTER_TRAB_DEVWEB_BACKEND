{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "run-spring-boot",
			"type": "shell",
			"command": "mvn",
			"args": [
				"spring-boot:run"
			],
			"isBackground": false,
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
		},
		{
			"label": "check-maven-version",
			"type": "shell",
			"command": "mvn",
			"args": [
				"-version"
			],
			"isBackground": false,
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
		},
		{
			"label": "check-maven-version-again",
			"type": "shell",
			"command": "mvn",
			"args": [
				"-version"
			],
			"isBackground": false,
			"problemMatcher": [
				"$msCompile"
			],
			"group": "build"
		}
	]
}